{
  "manifest_version": 3,
  "name": "Export Tabs as Shortcuts",
  "version": "1.0.0",
  "description": "One click saves every open tab as a clickable shortcut file: .webloc on macOS, .url on Windows and Linux.",
  "homepage_url": "https://github.com/bsc2fast/tab-export-extension",
  "minimum_chrome_version": "102",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "downloads"],
  "action": {
    "default_title": "Export tabs as shortcut files",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "bg.js"
  }
}
